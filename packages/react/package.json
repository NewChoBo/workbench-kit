{
  "name": "@workbench-kit/react",
  "version": "0.0.1-prototype.0",
  "private": false,
  "type": "module",
  "scripts": {
    "test": "pnpm exec vitest run --config ../../vitest.config.ts src/widget-tree",
    "typecheck": "tsc -p tsconfig.json --noEmit"
