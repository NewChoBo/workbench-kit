{
  "name": "@workbench-kit/react",
  "version": "0.0.1-prototype.0",
  "private": false,
  "type": "module",
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "exports": {
    ".": "./src/index.ts",
    "./primitives": "./src/primitives/index.ts",
    "./primitives.css": "./src/primitives/styles.css",
    "./workbench/auth": "./src/workbench/auth/index.ts",
    "./workbench/chat": "./src/workbench/chat/index.ts",
    "./workbench/settings": "./src/workbench/settings/index.ts",
    "./workbench": "./src/workbench/index.ts",
    "./workbench/demo": "./src/workbench/demo/index.ts",
    "./workbench/workspace": "./src/workbench/workspace/index.ts",
    "./json-config": "./src/json-config/index.ts",
    "./json-widget": "./src/json-widget/index.ts",
    "./styles.css": "./src/styles.css"
  },
  "files": [
    "src",
    "!src/**/*.test.ts",
    "!src/**/*.test.tsx",
    "!src/**/*.stories.ts",
    "!src/**/*.stories.tsx"
  ],
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@workbench-kit/core": "workspace:*",
    "@workbench-kit/adapters": "workspace:*",
    "@workbench-kit/contracts": "workspace:*",
    "@workbench-kit/json-widget": "workspace:*",
    "@workbench-kit/runtime": "workspace:*",
    "@workbench-kit/services": "workspace:*",
    "@workbench-kit/vscode-extension": "workspace:*",
    "@workbench-kit/tokens": "workspace:*",
    "@workbench-kit/workspace": "workspace:*",
    "@vscode/codicons": "^0.0.45"
  },
  "peerDependencies": {
    "@monaco-editor/react": "^4.7.0",
    "monaco-editor": "^0.55.1",
    "react-markdown": "^10.1.0",
    "react": "^19.0.0"
  },
  "peerDependenciesMeta": {
    "@monaco-editor/react": {
      "optional": true
    },
    "monaco-editor": {
      "optional": true
    },
    "react-markdown": {
      "optional": true
    }
  },
  "description": "React primitives and workbench components for Workbench Kit.",
  "publishConfig": {
    "access": "public",
    "tag": "prototype",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NewChoBo/newchobo-ui-package.git",
    "directory": "packages/react"
