    "@dnd-kit/core": "^6.3.1",
    "@workbench-kit/platform": "workspace:*",
    "@workbench-kit/adapters": "workspace:*",
    "@workbench-kit/contracts": "workspace:*",
    "@workbench-kit/jdw": "workspace:*",
    "@workbench-kit/runtime": "workspace:*",
    "@workbench-kit/services": "workspace:*",
    "@workbench-kit/tokens": "workspace:*",
    "@workbench-kit/workspace": "workspace:*",
    "@vscode/codicons": "^0.0.45"
  },
  "peerDependencies": {
    "@monaco-editor/react": "^4.7.0",
