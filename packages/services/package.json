{
  "name": "@workbench-kit/services",
  "version": "0.0.1-prototype.0",
  "private": false,
  "type": "module",
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "exports": {
    ".": "./src/index.ts",
    "./save": "./src/save.ts",
    "./chat": "./src/chat.ts",
    "./patch": "./src/patch.ts",
    "./library": "./src/library.ts"
  },
  "files": [
    "src",
    "!src/**/*.test.ts",
    "!src/**/*.test.tsx",
    "!src/**/*.stories.ts",
    "!src/**/*.stories.tsx"
  ],
  "dependencies": {
    "@workbench-kit/contracts": "workspace:*"
  },
  "description": "Workbench Kit orchestration services for chat, save, patch, and library flows.",
  "publishConfig": {
    "access": "public",
    "tag": "prototype",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NewChoBo/workbench-kit.git",
    "directory": "packages/services"
  }
}
