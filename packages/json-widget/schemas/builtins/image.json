{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://workbench-kit.dev/schemas/builtins/image.json",
  "title": "ImageWidget",
  "type": "object",
  "required": ["type", "args"],
  "properties": {
    "type": { "const": "image" },
    "id": { "type": "string" },
    "listen": {
      "type": "array",
      "items": { "type": "string" }
    },
    "args": {
      "type": "object",
      "required": ["src"],
      "properties": {
        "src": { "type": "string", "minLength": 1 },
        "alt": { "type": "string" },
        "fit": { "type": "string" },
        "width": {
          "oneOf": [
            { "type": "number", "minimum": 0 },
            { "type": "string", "pattern": "^\\$\\{[A-Za-z0-9_.-]+\\}$" }
          ]
        },
        "height": {
          "oneOf": [
            { "type": "number", "minimum": 0 },
            { "type": "string", "pattern": "^\\$\\{[A-Za-z0-9_.-]+\\}$" }
          ]
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
