{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://workbench-kit.dev/schemas/builtins/center.json",
  "title": "CenterWidget",
  "type": "object",
  "required": ["type", "args"],
  "properties": {
    "type": { "const": "center" },
    "id": { "type": "string" },
    "listen": {
      "type": "array",
