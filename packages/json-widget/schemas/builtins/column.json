{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://workbench-kit.dev/schemas/builtins/column.json",
  "title": "ColumnWidget",
  "type": "object",
  "required": ["type", "args"],
  "properties": {
    "type": { "const": "column" },
    "id": { "type": "string" },
    "listen": {
      "type": "array",
      "items": { "type": "string" }
    },
    "args": {
      "type": "object",
      "properties": {
        "gap": { "type": "number", "minimum": 0 },
        "padding": { "type": "number", "minimum": 0 },
        "background": { "type": "string" },
        "mainAxisAlignment": { "type": "string" },
        "crossAxisAlignment": { "type": "string" },
        "children": {
          "type": "array",
          "items": { "$ref": "../jdw-node.json" }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
