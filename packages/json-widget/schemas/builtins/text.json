{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://workbench-kit.dev/schemas/builtins/text.json",
  "title": "TextWidget",
  "type": "object",
  "required": ["type", "args"],
  "properties": {
    "type": { "const": "text" },
    "id": { "type": "string" },
    "listen": {
      "type": "array",
      "items": { "type": "string" }
    },
    "args": {
      "type": "object",
      "required": ["text"],
      "properties": {
        "text": { "type": "string" },
        "color": { "type": "string" },
        "background": { "type": "string" },
        "fontSize": { "type": "number", "minimum": 1 }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
