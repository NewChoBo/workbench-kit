{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://workbench-kit.dev/schemas/builtins/row.json",
  "title": "RowWidget",
  "type": "object",
  "required": ["type", "args"],
  "properties": {
    "type": { "const": "row" },
    "id": { "type": "string" },
    "listen": {
      "type": "array",
      "items": { "type": "string" }
    },
    "args": {
      "type": "object",
      "properties": {
        "gap": {
          "oneOf": [
            { "type": "number", "minimum": 0 },
            { "type": "string", "pattern": "^\\$\\{[A-Za-z0-9_.-]+\\}$" }
          ]
        },
        "padding": {
          "oneOf": [
            { "type": "number", "minimum": 0 },
            { "type": "string", "pattern": "^\\$\\{[A-Za-z0-9_.-]+\\}$" }
          ]
        },
        "background": { "type": "string" },
        "mainAxisAlignment": {
          "oneOf": [
            {
              "type": "string",
              "enum": ["start", "center", "end", "spaceBetween", "spaceAround", "spaceEvenly"]
            },
            { "type": "string", "pattern": "^\\$\\{[A-Za-z0-9_.-]+\\}$" }
          ]
        },
        "crossAxisAlignment": {
          "oneOf": [
            { "type": "string", "enum": ["stretch", "start", "center", "end"] },
            { "type": "string", "pattern": "^\\$\\{[A-Za-z0-9_.-]+\\}$" }
          ]
        },
        "children": {
          "type": "array",
          "items": { "$ref": "../jdw-node.jdw.schema.json" }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
