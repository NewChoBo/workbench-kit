{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://workbench-kit.dev/schemas/widget-asset-manifest.v1.jdw.schema.json",
  "title": "WidgetAssetManifestV1",
  "description": "Catalog metadata for a directory-based widget asset package.",
  "type": "object",
  "required": ["name", "label", "category"],
  "properties": {
    "$schema": { "type": "string" },
    "name": { "type": "string", "minLength": 1 },
    "version": { "type": "string" },
    "label": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "category": { "type": "string", "minLength": 1 },
    "kind": {
      "type": "string",
      "enum": ["leaf", "container", "template"]
    },
    "icon": { "type": "string" },
    "placementPolicy": { "type": "string" }
  },
  "additionalProperties": false
}
