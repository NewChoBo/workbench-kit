{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://workbench-kit.dev/schemas/extensions/button.json",
  "title": "ButtonWidget",
  "description": "Workbench kit extension static button preview.",
  "type": "object",
  "required": ["type", "args"],
  "properties": {
    "type": { "const": "button" },
    "id": { "type": "string" },
    "listen": {
      "type": "array",
      "items": { "type": "string" }
    },
    "args": {
      "type": "object",
      "required": ["label"],
      "properties": {
        "label": { "type": "string", "minLength": 1 },
        "variant": { "type": "string" },
        "color": { "type": "string" },
        "background": { "type": "string" },
        "disabled": {
          "oneOf": [
            { "type": "boolean" },
            { "type": "string", "pattern": "^\\$\\{[A-Za-z0-9_.-]+\\}$" }
          ]
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
