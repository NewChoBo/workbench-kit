{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://workbench-kit.dev/schemas/extensions/box.json",
  "title": "BoxWidget",
  "description": "Workbench kit extension single-child wrapper.",
  "type": "object",
  "required": ["type", "args"],
  "properties": {
    "type": { "const": "box" },
    "id": { "type": "string" },
    "listen": {
      "type": "array",
      "items": { "type": "string" }
    },
    "args": {
      "type": "object",
      "properties": {
        "width": {
          "oneOf": [
            { "type": "number", "minimum": 0 },
            { "type": "string", "pattern": "^\\$\\{[A-Za-z0-9_.-]+\\}$" }
          ]
        },
        "height": {
          "oneOf": [
            { "type": "number", "minimum": 0 },
            { "type": "string", "pattern": "^\\$\\{[A-Za-z0-9_.-]+\\}$" }
          ]
        },
        "padding": {
          "oneOf": [
            { "type": "number", "minimum": 0 },
            { "type": "string", "pattern": "^\\$\\{[A-Za-z0-9_.-]+\\}$" }
          ]
        },
        "background": { "type": "string" },
        "child": { "$ref": "../jdw-node.jdw.schema.json" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
