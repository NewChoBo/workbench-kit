        "id": { "type": "string", "minLength": 1 },
        "listen": {
          "type": "array",
          "items": { "type": "string" }
        },
        "args": {
          "type": "object",
          "allOf": [{ "$ref": "#/definitions/JdwPlacementArgs" }],
          "properties": {
            "gap": {
              "oneOf": [
                { "type": "number", "minimum": 0 },
