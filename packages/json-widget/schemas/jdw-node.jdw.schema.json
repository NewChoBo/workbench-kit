    "JdwDynamicValue": {
      "title": "JdwDynamicValue",
      "description": "Exact ${path} expression resolved from explicit render or preview values.",
      "type": "string",
      "pattern": "^\\$\\{[A-Za-z0-9_.-]+\\}$"
    },
