{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://workbench-kit.dev/schemas/jdw-node.jdw.schema.json",
  "title": "JsonWidgetNode",
  "description": "Recursive JDW v7 widget envelope (type + args).",
  "$ref": "#/definitions/JdwNode",
  "definitions": {
    "JdwDynamicValue": {
      "title": "JdwDynamicValue",
      "description": "Exact ${path} expression resolved from explicit render or preview values.",
      "type": "string",
      "pattern": "^\\$\\{[A-Za-z0-9_.-]+\\}$"
    },
    "JdwPlacementArgs": {
      "title": "JdwPlacementArgs",
      "description": "Parent-scoped placement hints used by row/column, grid, and stack containers.",
      "type": "object",
      "properties": {
        "width": {
          "oneOf": [{ "type": "number", "minimum": 0 }, { "$ref": "#/definitions/JdwDynamicValue" }]
        },
        "height": {
          "oneOf": [{ "type": "number", "minimum": 0 }, { "$ref": "#/definitions/JdwDynamicValue" }]
        },
        "flex": {
          "oneOf": [{ "type": "number", "minimum": 0 }, { "$ref": "#/definitions/JdwDynamicValue" }]
        },
        "flexFit": {
          "oneOf": [
            { "type": "string", "enum": ["tight", "loose"] },
            { "$ref": "#/definitions/JdwDynamicValue" }
          ]
        },
        "align": {
          "oneOf": [
            { "type": "string", "enum": ["stretch", "start", "center", "end"] },
            { "$ref": "#/definitions/JdwDynamicValue" }
          ]
        },
        "col": {
          "oneOf": [{ "type": "number", "minimum": 0 }, { "$ref": "#/definitions/JdwDynamicValue" }]
        },
        "row": {
          "oneOf": [{ "type": "number", "minimum": 0 }, { "$ref": "#/definitions/JdwDynamicValue" }]
        },
        "colSpan": {
          "oneOf": [{ "type": "number", "minimum": 1 }, { "$ref": "#/definitions/JdwDynamicValue" }]
        },
        "rowSpan": {
          "oneOf": [{ "type": "number", "minimum": 1 }, { "$ref": "#/definitions/JdwDynamicValue" }]
        },
        "left": {
          "oneOf": [{ "type": "number" }, { "$ref": "#/definitions/JdwDynamicValue" }]
        },
        "top": {
          "oneOf": [{ "type": "number" }, { "$ref": "#/definitions/JdwDynamicValue" }]
        },
        "right": {
          "oneOf": [{ "type": "number" }, { "$ref": "#/definitions/JdwDynamicValue" }]
        },
        "bottom": {
          "oneOf": [{ "type": "number" }, { "$ref": "#/definitions/JdwDynamicValue" }]
        }
      }
    },
    "JdwNode": {
      "oneOf": [
        { "$ref": "#/definitions/TextJdwNode" },
        { "$ref": "#/definitions/RowJdwNode" },
        { "$ref": "#/definitions/ColumnJdwNode" },
        { "$ref": "#/definitions/ExpandedJdwNode" },
        { "$ref": "#/definitions/FlexibleJdwNode" },
        { "$ref": "#/definitions/StackJdwNode" },
        { "$ref": "#/definitions/ContainerJdwNode" },
        { "$ref": "#/definitions/PaddingJdwNode" },
        { "$ref": "#/definitions/AlignJdwNode" },
        { "$ref": "#/definitions/CenterJdwNode" },
        { "$ref": "#/definitions/SizedBoxJdwNode" },
        { "$ref": "#/definitions/ImageJdwNode" },
        { "$ref": "#/definitions/IconJdwNode" },
        { "$ref": "#/definitions/GridJdwNode" },
        { "$ref": "#/definitions/BoxJdwNode" },
        { "$ref": "#/definitions/ButtonJdwNode" },
        { "$ref": "#/definitions/CustomJdwNode" }
      ]
    },
    "CustomJdwNode": {
      "title": "CustomJdwNode",
      "type": "object",
      "required": ["type", "args"],
      "properties": {
        "type": {
          "type": "string",
          "minLength": 1,
          "not": {
            "enum": [
              "text",
              "row",
              "column",
              "expanded",
              "flexible",
              "stack",
              "container",
              "padding",
              "align",
              "center",
              "sized_box",
              "image",
              "icon",
              "grid",
              "box",
              "button"
            ]
          }
        },
        "$schema": { "type": "string", "minLength": 1 },
        "id": { "type": "string", "minLength": 1 },
        "listen": {
          "type": "array",
          "items": { "type": "string" }
        },
        "args": { "type": "object" }
      },
      "additionalProperties": false
    },
    "TextJdwNode": {
      "title": "TextJdwNode",
      "type": "object",
      "required": ["type", "args"],
      "properties": {
        "type": { "const": "text" },
        "$schema": { "type": "string", "minLength": 1 },
        "id": { "type": "string", "minLength": 1 },
        "listen": {
          "type": "array",
          "items": { "type": "string" }
        },
        "args": {
          "type": "object",
          "allOf": [{ "$ref": "#/definitions/JdwPlacementArgs" }],
          "required": ["text"],
          "properties": {
            "text": { "type": "string" },
            "color": { "type": "string" },
            "background": { "type": "string" },
            "fontSize": {
              "oneOf": [
                { "type": "number", "minimum": 1 },
                { "$ref": "#/definitions/JdwDynamicValue" }
              ]
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    },
    "RowJdwNode": {
      "title": "RowJdwNode",
