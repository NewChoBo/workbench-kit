            },
            {
              "$ref": "#/definitions/JdwDynamicValue"
            }
          ]
        },
        "colSpan": {
          "oneOf": [
            {
              "type": "number",
              "minimum": 1
            },
            {
              "$ref": "#/definitions/JdwDynamicValue"
            }
          ]
