{
  "name": "@workbench-kit/jdw",
  "version": "0.0.1-prototype.0",
  "private": false,
  "type": "module",
  "scripts": {
    "build": "tsup",
    "test": "pnpm exec vitest run --config ../../vitest.config.ts src",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "schemas",
    "src",
    "!src/**/*.test.ts",
    "!src/**/*.test.tsx",
    "!src/**/*.stories.ts",
    "!src/**/*.stories.tsx"
  ],
  "dependencies": {
    "@workbench-kit/contracts": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.5.0"
  },
  "description": "Framework-neutral JDW engine: parse, layout, screen-spec compile, and widget document ops.",
  "publishConfig": {
    "access": "public",
    "tag": "prototype",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NewChoBo/newchobo-ui-package.git",
    "directory": "packages/json-widget"
  }
}
