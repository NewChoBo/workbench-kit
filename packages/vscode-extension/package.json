{
  "name": "@workbench-kit/vscode-extension",
  "version": "0.0.1-prototype.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "vitest run src",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "src",
    "!src/**/*.test.ts",
    "!src/**/*.test.tsx",
    "!src/**/*.stories.ts",
    "!src/**/*.stories.tsx"
  ],
  "dependencies": {
    "@workbench-kit/adapters": "workspace:*",
    "@workbench-kit/contracts": "workspace:*",
    "@workbench-kit/platform": "workspace:*",
    "@workbench-kit/services": "workspace:*",
    "@workbench-kit/vscode-host": "workspace:*"
  },
  "peerDependencies": {
    "@workbench-kit/services": "0.0.1-prototype.0"
  },
  "description": "Private preview VS Code extension bootstrap helpers for Workbench Kit.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NewChoBo/workbench-kit.git",
    "directory": "packages/vscode-extension"
  }
}
