{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/NewChoBo/workbench-kit/schemas/workbench/workspace.schema.json",
  "title": "Workbench Workspace",
  "type": "object",
  "properties": {
    "version": {
      "type": "integer",
      "description": "Schema version for workspace.json"
    },
    "name": {
      "type": "string",
      "description": "Human-readable workspace name"
    },
    "folders": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "path": { "type": "string" },
          "name": { "type": "string" }
        },
        "required": ["path"]
      }
    }
  },
  "additionalProperties": true
}
