{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/NewChoBo/workbench-kit/schemas/workbench/layout.schema.json",
  "title": "Workbench Layout",
  "type": "object",
  "properties": {
    "activityBar": {
      "type": "object",
      "properties": {
        "visible": { "type": "boolean" }
      }
    },
    "sideBar": {
      "type": "object",
      "properties": {
        "visible": { "type": "boolean" },
        "activeViewContainer": { "type": "string" }
      }
    },
    "panel": {
      "type": "object",
      "properties": {
        "visible": { "type": "boolean" }
      }
    }
  },
  "additionalProperties": true
}
