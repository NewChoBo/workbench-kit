{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/NewChoBo/workbench-kit/schemas/workbench/layout.schema.json",
  "title": "Workbench Layout",
  "type": "object",
  "properties": {
    "activityBar": {
      "type": "object",
      "properties": {
        "hiddenItemIds": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "itemOrder": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "visible": { "type": "boolean" }
      },
      "required": ["visible"],
      "additionalProperties": false
    },
    "sideBar": {
      "type": "object",
      "properties": {
        "activeViewContainer": { "type": "string", "minLength": 1 },
        "sizePercent": {
          "type": "number",
          "minimum": 10,
          "maximum": 90
        },
        "visible": { "type": "boolean" }
      },
      "required": ["visible"],
      "additionalProperties": false
    },
    "panel": {
      "type": "object",
      "properties": {
        "visible": { "type": "boolean" }
      },
      "required": ["visible"],
      "additionalProperties": false
    }
  },
  "required": ["activityBar", "sideBar", "panel"],
  "additionalProperties": false
}
