{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/NewChoBo/workbench-kit/schemas/workbench/layout.schema.json",
  "title": "Workbench Layout",
  "type": "object",
  "properties": {
    "activityBar": {
      "type": "object",
      "properties": {
        "visible": { "type": "boolean" }
      },
      "required": ["visible"],
      "additionalProperties": false
    },
    "sideBar": {
      "type": "object",
      "properties": {
        "visible": { "type": "boolean" },
        "activeViewContainer": { "type": "string", "minLength": 1 }
      },
      "required": ["visible"],
      "additionalProperties": false
    },
    "panel": {
      "type": "object",
      "properties": {
        "visible": { "type": "boolean" }
      },
      "required": ["visible"],
      "additionalProperties": false
    }
  },
  "required": ["activityBar", "sideBar", "panel"],
  "additionalProperties": false
}
