{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/NewChoBo/workbench-kit/schemas/workbench/extension-manifest.schema.json",
  "title": "Workbench Extension Manifest",
  "type": "object",
  "properties": {
    "schemaVersion": { "const": 1 },
    "id": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "displayName": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "publisher": { "type": "string", "minLength": 1 },
    "engines": {
      "type": "object",
      "properties": {
        "workbench": { "type": "string", "minLength": 1 },
        "extensionApi": { "type": "string", "minLength": 1 }
      },
      "required": ["workbench", "extensionApi"],
      "additionalProperties": true
    },
    "activationEvents": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "contributes": {
      "type": "object",
      "additionalProperties": true
    },
    "extensionDependencies": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "extensionOptionalDependencies": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "extensionPack": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "capabilities": {
      "type": "object",
      "properties": {
        "requires": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "provides": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      },
      "additionalProperties": true
    },
    "permissions": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    }
  },
  "required": [
    "schemaVersion",
    "id",
    "name",
    "displayName",
    "version",
    "publisher",
    "engines",
    "activationEvents"
  ],
  "additionalProperties": true
}
