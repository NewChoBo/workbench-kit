{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/NewChoBo/workbench-kit/schemas/workbench/extensions-lock.schema.json",
  "title": "Workbench Extensions Lock",
  "type": "object",
  "properties": {
    "lockfileVersion": {
      "type": "integer"
    },
    "extensions": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "version": { "type": "string" },
          "integrity": { "type": "string" }
        },
        "required": ["version"]
      }
    }
  },
  "additionalProperties": true
}
