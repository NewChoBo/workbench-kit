{
  "name": "workbench-kit",
  "version": "0.0.1-prototype.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.5.1",
  "scripts": {
    "preinstall": "node -e \"const execPath = process.env.npm_execpath || ''; if (!/pnpm/.test(execPath)) { console.error('This repository requires pnpm. Please run `pnpm install`.'); process.exit(1); }\"",
    "postinstall": "node scripts/postinstall-workspace-build.mjs",
    "build:workbench-extensions": "node scripts/bundle-workbench-extensions.mjs",
    "build:workspace": "node scripts/build-workspace-packages.mjs",
    "dev": "pnpm workbench-sample",
    "format": "pnpm exec prettier . --write",
    "format:check": "pnpm exec prettier . --check",
    "test:storybook-play": "pnpm exec node ./scripts/test-storybook-play.mjs",
    "test:storybook-play:required": "pnpm exec node ./scripts/test-storybook-play.mjs --required",
    "lint": "pnpm exec eslint .",
    "lint:fix": "pnpm exec eslint . --fix",
    "test": "pnpm exec vitest run",
    "test:widget-tree": "pnpm exec vitest run packages/json-widget/src/jdw-node.test.ts packages/json-widget/src/document.test.ts packages/json-widget/src/apply-widget-document-patch.test.ts packages/json-widget/src/widget-asset-file.test.ts packages/json-widget/src/validate-json-widget-data.test.ts packages/json-widget/src/validate-widget-asset.test.ts packages/json-widget/src/widget-placement-asset.test.ts packages/json-widget/src/widget-asset-package.test.ts packages/json-widget/src/widget-normalize.test.ts packages/json-widget/src/layout/layout-widget.test.ts packages/json-widget/src/widget-patch-materialize.test.ts packages/react/src/jdw packages/react/src/widget-tree packages/react/src/widget-asset packages/react/src/widget-studio",
    "build:storybook": "pnpm exec storybook build",
    "storybook": "pnpm exec storybook dev --port 6010 --host 127.0.0.1 --no-open",
    "storybook:components": "pnpm exec storybook dev --port 6010 --host 127.0.0.1 --no-open --initial-path=/iframe.html?id=react-primitives-controls--form-controls&viewMode=story",
    "storybook:sample": "pnpm exec storybook dev --port 6010 --host 127.0.0.1 --no-open --initial-path=/iframe.html?id=workbench-sample-dev-app--tester-dev-app-journey&viewMode=story",
    "storybook:chat": "pnpm exec storybook dev --port 6010 --host 127.0.0.1 --no-open --initial-path=/iframe.html?id=react-workbench-chat-components--sample-peer-chat-example&viewMode=story",
    "workbench-sample": "pnpm --filter workbench-sample dev",
    "workbench-sample:build": "pnpm --filter workbench-sample build",
    "check:extension-manifests": "node ./scripts/check-workbench-extension-manifests.mjs",
    "check:public-exports": "node ./scripts/check-public-package-exports.mjs",
    "check:dependency-graph": "node ./scripts/check-workbench-dependency-graph.mjs",
    "check:launch-boundary": "node ./scripts/check-launch-boundary.mjs",
    "check:workspace-isolation": "node ./scripts/check-workspace-isolation.mjs",
    "typecheck": "pnpm --filter \"@workbench-kit/*\" --if-present typecheck",
    "typecheck:foundation": "pnpm --filter @workbench-kit/base --filter @workbench-kit/platform --filter @workbench-kit/contracts --filter @workbench-kit/services --filter @workbench-kit/runtime --filter @workbench-kit/adapters --if-present typecheck",
    "typecheck:workbench": "pnpm --filter \"@workbench-kit/workbench-*\" --filter @workbench-kit/shell-react --filter @workbench-kit/workspace --if-present typecheck",
    "typecheck:jdw": "pnpm --filter \"@workbench-kit/jdw*\" --filter @workbench-kit/react --if-present typecheck",
    "validate:static": "pnpm typecheck && pnpm lint && pnpm format:check && pnpm check:extension-manifests && pnpm check:public-exports && pnpm check:dependency-graph && pnpm check:launch-boundary && pnpm check:workspace-isolation",
    "validate:fast": "pnpm validate:static && pnpm test",
    "validate:ui": "pnpm build:storybook && pnpm test:storybook-play:required",
    "validate:ui:full": "pnpm build:storybook && pnpm test:storybook-play:required",
    "validate": "pnpm validate:fast && pnpm validate:ui",
    "validate:full": "pnpm validate:fast && pnpm validate:ui:full",
    "release:check": "node scripts/check-release-version.mjs",
    "sync:version-from-tag": "node scripts/sync-version-from-tag.mjs",
    "preflight:npm-publish": "node scripts/preflight-npm-publish.mjs",
    "publish:packages": "node scripts/publish-packages.mjs",
    "publish:packages:dry-run": "node scripts/publish-packages.mjs --dry-run",
    "publish:packages:local": "node scripts/publish-packages-local.mjs",
    "publish:packages:local:dry-run": "node scripts/publish-packages-local.mjs --dry-run"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@monaco-editor/react": "^4.7.0",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/react-vite": "^10.4.6",
    "@storybook/test-runner": "^0.24.4",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "monaco-editor": "^0.55.1",
    "playwright": "1.60.0",
    "prettier": "^3.8.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "storybook": "^10.4.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.60.1",
    "vite": "^6.0.0",
    "vitest": "^4.1.8",
    "eslint-plugin-storybook": "10.4.6"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NewChoBo/workbench-kit.git"
  }
}
