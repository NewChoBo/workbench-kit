{
  "name": "newchobo-ui-package",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "preinstall": "node -e \"const execPath = process.env.npm_execpath || ''; if (!/pnpm/.test(execPath)) { console.error('This repository requires pnpm. Please run `pnpm install`.'); process.exit(1); }\"",
    "format": "pnpm exec prettier . --write",
    "format:check": "pnpm exec prettier . --check",
    "test:storybook-play": "pnpm exec node ./scripts/test-storybook-play.mjs",
    "lint": "pnpm exec eslint .",
    "lint:fix": "pnpm exec eslint . --fix",
    "test": "pnpm exec vitest run",
    "build:storybook": "pnpm exec storybook build",
    "storybook": "pnpm exec storybook dev --port 6010 --host 127.0.0.1 --no-open",
    "typecheck": "pnpm --filter @newchobo-ui/core typecheck && pnpm --filter @newchobo-ui/workspace typecheck && pnpm --filter @newchobo-ui/runtime typecheck && pnpm --filter @newchobo-ui/react typecheck",
    "validate": "pnpm typecheck && pnpm lint && pnpm test && pnpm format:check && pnpm build:storybook",
    "validate:full": "pnpm validate && pnpm test:storybook-play"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@monaco-editor/react": "^4.7.0",
    "@storybook/addon-docs": "^10.4.1",
    "@storybook/react-vite": "^10.4.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "monaco-editor": "^0.55.1",
    "prettier": "^3.8.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "storybook": "^10.4.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.60.1",
    "vite": "^6.0.0",
    "vitest": "^4.1.8"
  }
}
