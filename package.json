{
  "name": "workbench-kit",
  "version": "0.0.1-prototype.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.5.1",
  "scripts": {
    "preinstall": "node -e \"const execPath = process.env.npm_execpath || ''; if (!/pnpm/.test(execPath)) { console.error('This repository requires pnpm. Please run `pnpm install`.'); process.exit(1); }\"",
    "prepare": "husky",
    "postinstall": "node scripts/postinstall-workspace-build.mjs",
    "precommit": "pnpm exec lint-staged && node scripts/typecheck-staged-packages.mjs",
    "prepush": "pnpm typecheck && pnpm lint && pnpm test && pnpm format:check",
    "build:workspace": "node scripts/build-workspace-packages.mjs",
    "format": "pnpm exec prettier . --write",
    "format:check": "pnpm exec prettier . --check",
    "test:storybook-play": "pnpm exec node ./scripts/test-storybook-play.mjs",
    "test:storybook-play:required": "pnpm exec node ./scripts/test-storybook-play.mjs --required",
    "lint": "pnpm exec eslint .",
    "lint:fix": "pnpm exec eslint . --fix",
    "test": "pnpm exec vitest run",
    "build:storybook": "pnpm exec storybook build",
    "storybook": "pnpm exec storybook dev --port 6010 --host 127.0.0.1 --no-open",
    "dev:widget-authoring": "pnpm --filter @workbench-kit/widget-authoring dev",
    "build:widget-authoring": "pnpm --filter @workbench-kit/widget-authoring build",
    "check:launch-boundary": "node ./scripts/check-launch-boundary.mjs",
    "typecheck:root": "pnpm exec tsc -p tsconfig.json --noEmit",
    "typecheck": "pnpm --filter @workbench-kit/core typecheck && pnpm --filter @workbench-kit/contracts typecheck && pnpm --filter @workbench-kit/json-widget typecheck && pnpm --filter @workbench-kit/services typecheck && pnpm --filter @workbench-kit/workspace typecheck && pnpm --filter @workbench-kit/runtime typecheck && pnpm --filter @workbench-kit/adapters typecheck && pnpm --filter @workbench-kit/react typecheck && pnpm --filter @workbench-kit/vscode-host typecheck && pnpm --filter @workbench-kit/widget-authoring typecheck",
    "typecheck:all": "pnpm typecheck && pnpm --filter @workbench-kit/vscode-extension typecheck",
    "validate": "pnpm typecheck && pnpm lint && pnpm test && pnpm format:check && pnpm build:storybook && pnpm check:launch-boundary",
    "validate:full": "pnpm validate && pnpm test:storybook-play:required",
    "release:check": "node scripts/check-release-version.mjs",
    "sync:version-from-tag": "node scripts/sync-version-from-tag.mjs",
    "preflight:npm-publish": "node scripts/preflight-npm-publish.mjs",
    "publish:packages": "node scripts/publish-packages.mjs",
    "publish:packages:dry-run": "node scripts/publish-packages.mjs --dry-run"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@monaco-editor/react": "^4.7.0",
    "@storybook/addon-docs": "^10.4.1",
    "@storybook/react-vite": "^10.4.1",
    "@storybook/test-runner": "^0.24.4",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "monaco-editor": "^0.55.1",
    "playwright": "^1.60.0",
    "prettier": "^3.8.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "storybook": "^10.4.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.60.1",
    "vite": "^6.0.0",
    "vitest": "^4.1.8"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,json,md}": [
      "prettier --write"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NewChoBo/newchobo-ui-package.git"
  }
}
