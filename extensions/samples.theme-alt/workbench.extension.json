{
  "schemaVersion": 1,
  "id": "workbench-kit.samples.theme-alt",
  "name": "samples-theme-alt",
  "displayName": "Alternate Theme Pack",
  "version": "0.0.0",
  "publisher": "workbench-kit",
  "engines": {
    "workbench": "^0.0.0",
    "extensionApi": "^0.0.0"
  },
  "activationEvents": ["onStartup"],
  "contributes": {
    "themes": [
      {
        "id": "workbench-kit.samples.theme-alt.dark-blue",
        "label": "Dark Blue Alt",
        "mode": "dark",
        "tokenOverrides": {
          "--color-bg": "#0a1628",
          "--color-bg-75": "rgba(10, 22, 40, 0.75)",
          "--color-primary-side-bar-bg": "#08111f",
          "--color-primary-side-bar-bg-75": "rgba(8, 17, 31, 0.75)",
          "--color-surface": "#12243d",
          "--color-surface-hover": "#17304f",
          "--color-surface-elevated": "#17304f",
          "--color-border": "#1d3a5c",
          "--color-text": "#e6eef7",
          "--color-text-muted": "#93a8c2",
          "--color-text-subtle": "#66819f",
          "--color-accent": "#5b9bd5",
          "--color-accent-hover": "#4a85bd",
          "--color-accent-foreground": "#ffffff",
          "--color-focus-border": "#5b9bd5",
          "--color-danger": "#f87171",
          "--color-danger-hover": "#fca5a5",
          "--scrollbar-thumb": "#1d3a5c66",
          "--scrollbar-thumb-hover": "#2f547f88",
          "--scrollbar-thumb-active": "#4a749eaa"
        }
      }
    ]
  }
}
